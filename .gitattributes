# 统一换行符为 LF，避免 Windows/WSL 编辑器引入 CRLF 噪音
# 文本文件自动检测并在仓库中以 LF 存储
* text=auto eol=lf

# 明确指定常见文本类型使用 LF
*.md      text eol=lf
*.py      text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.sh      text eol=lf
*.txt     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.env     text eol=lf
*.example text eol=lf

# 二进制文件不做换行符转换
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.docx binary
*.xlsx binary
*.xls  binary
*.zip  binary
*.ico  binary
