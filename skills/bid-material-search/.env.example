# MaterialHub API 配置
# 将此文件复制为 .env 并填写实际值

# MaterialHub API 服务器地址
# 本地开发: http://localhost:8201
# 远程服务器: http://your-server-ip:8201 或 https://your-domain.com
MATERIALHUB_API_URL=http://localhost:8201

# MaterialHub API 密钥
# 从服务器的 .env 文件获取 MATERIALHUB_API_KEY
MATERIALHUB_API_KEY=mh-mcp-xxx...

# 可选：HTTP 代理配置（如果需要通过代理访问服务器）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
